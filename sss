local MobileAimbot = {}
MobileAimbot.Enabled = false
MobileAimbot.ConnectionLoop = nil
MobileAimbot.ConnectionTouch = nil
MobileAimbot.FOVCircle = nil
MobileAimbot.LockedTarget = nil
MobileAimbot.ActiveTouches = {}  -- [touchId] = true → toques activos en derecha

local function isMobile()
    return UserInputService.TouchEnabled and not UserInputService.MouseEnabled
end

-- Cuántos toques activos hay en la derecha
local function getActiveRightTouchesCount()
    local count = 0
    for _ in pairs(MobileAimbot.ActiveTouches) do
        count = count + 1
    end
    return count
end

-- Crear/actualizar círculo FOV
local function updateMobileFOVCircle()
    if MobileAimbot.FOVCircle then
        MobileAimbot.FOVCircle:Remove()
    end
    
    if not isMobile() then return end
    
    MobileAimbot.FOVCircle = Drawing.new("Circle")
    MobileAimbot.FOVCircle.Thickness = 2
    MobileAimbot.FOVCircle.NumSides = 100
    MobileAimbot.FOVCircle.Radius = FOVSettings.Radius or 150
    MobileAimbot.FOVCircle.Color = FOVSettings.Color or Color3.fromRGB(255, 255, 255)
    MobileAimbot.FOVCircle.Transparency = 1
    MobileAimbot.FOVCircle.Visible = FOVSettings.Visible or false
    MobileAimbot.FOVCircle.Filled = false
end

-- ¿El toque está en la mitad derecha?
local function isRightSideTouch(touchPos)
    local screenWidth = workspace.CurrentCamera.ViewportSize.X
    return touchPos.X > screenWidth * 0.5
end

-- Encontrar mejor objetivo
local function findBestTarget()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end

    local camera = workspace.CurrentCamera
    local cameraPos = camera.CFrame.Position
    local closest = nil
    local bestDot = -1

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        
        local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then continue end
        
        local part = player.Character:FindFirstChild(AimbotSettings.LockPart or "Head")
        if not part then continue end
        
        local direction = (part.Position - cameraPos)
        local rayParams = RaycastParams.new()
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        rayParams.FilterType = Enum.RaycastFilterType.Exclude
        
        local result = workspace:Raycast(cameraPos, direction.Unit * 5000, rayParams)
        if result and result.Instance:IsDescendantOf(player.Character) then
            local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
                local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                
                if dist <= (FOVSettings.Radius or 150) then
                    local dot = 1 - (dist / (FOVSettings.Radius or 150))
                    if dot > bestDot then
                        bestDot = dot
                        closest = part
                    end
                end
            end
        end
    end
    
    return closest
end

-- Loop principal
local function mobileAimbotLoop(deltaTime)
    local activeCount = getActiveRightTouchesCount()
    
    -- Actualizar FOV siempre (centrado)
    if MobileAimbot.FOVCircle then
        local center = Vector2.new(workspace.CurrentCamera.ViewportSize.X / 2, workspace.CurrentCamera.ViewportSize.Y / 2)
        MobileAimbot.FOVCircle.Position = center
        
        if rainbowFOV then
            local hue = tick() % 3 / 3
            MobileAimbot.FOVCircle.Color = Color3.fromHSV(hue, 1, 1)
        end
        
        MobileAimbot.FOVCircle.Visible = FOVSettings.Visible
        MobileAimbot.FOVCircle.Radius = FOVSettings.Radius or 150
    end
    
    -- Solo apuntamos si hay al menos 1 toque activo en derecha
    if not MobileAimbot.Enabled or activeCount == 0 then return end
    
    -- Mantener lock (no cambia hasta que se liberen TODOS los toques)
    local targetPart = MobileAimbot.LockedTarget
    
    if not targetPart or not targetPart.Parent or not targetPart.Parent:FindFirstChildOfClass("Humanoid") then
        targetPart = findBestTarget()
        MobileAimbot.LockedTarget = targetPart
    end
    
    if targetPart and targetPart.Parent then
        local camera = workspace.CurrentCamera
        
        -- Predicción
        local predictedPos = targetPart.Position
        local root = targetPart.Parent:FindFirstChild("HumanoidRootPart")
        if root then
            predictedPos = predictedPos + root.Velocity * 0.12
        end
        
        -- Apuntar recto
        local targetCFrame = CFrame.lookAt(camera.CFrame.Position, predictedPos, Vector3.new(0, 1, 0))
        
        local baseSmooth = AimbotSettings.Sensitivity or 0.1
        local smooth = math.clamp(baseSmooth * 4, 0.2, 0.9)
        
        camera.CFrame = camera.CFrame:Lerp(targetCFrame, smooth * deltaTime * 60)
        
        -- Snap
        local center = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
        local screenPos, _ = camera:WorldToViewportPoint(predictedPos)
        local pixelDist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
        if pixelDist < 25 then
            camera.CFrame = targetCFrame
        end
    end
end

-- Toque iniciado
local function onInputBegan(input, gameProcessed)
    if not MobileAimbot.Enabled then return end
    if gameProcessed then return end
    if input.UserInputType ~= Enum.UserInputType.Touch then return end
    
    local touchPos = input.Position
    if isRightSideTouch(touchPos) then
        local touchId = input.Id
        MobileAimbot.ActiveTouches[touchId] = true
        
        -- Si es el primer toque → lock objetivo
        if getActiveRightTouchesCount() == 1 then
            MobileAimbot.LockedTarget = findBestTarget()
        end
        
        if not MobileAimbot.ConnectionLoop then
            MobileAimbot.ConnectionLoop = RunService.RenderStepped:Connect(mobileAimbotLoop)
        end
    end
end

-- Toque terminado
local function onInputEnded(input, gameProcessed)
    if input.UserInputType ~= Enum.UserInputType.Touch then return end
    
    local touchId = input.Id
    MobileAimbot.ActiveTouches[touchId] = nil
    
    -- Solo libera lock si ya no queda ningún toque en derecha
    if getActiveRightTouchesCount() == 0 then
        MobileAimbot.LockedTarget = nil
    end
end

-- Iniciar
local function startMobileAimbot()
    if MobileAimbot.ConnectionLoop then return end
    
    updateMobileFOVCircle()
    
    MobileAimbot.ConnectionLoop = RunService.RenderStepped:Connect(mobileAimbotLoop)
    MobileAimbot.ConnectionTouch = {}
    table.insert(MobileAimbot.ConnectionTouch, UserInputService.InputBegan:Connect(onInputBegan))
    table.insert(MobileAimbot.ConnectionTouch, UserInputService.InputEnded:Connect(onInputEnded))
end

-- Detener
local function stopMobileAimbot()
    if MobileAimbot.ConnectionLoop then
        MobileAimbot.ConnectionLoop:Disconnect()
        MobileAimbot.ConnectionLoop = nil
    end
    
    if MobileAimbot.ConnectionTouch then
        for _, conn in ipairs(MobileAimbot.ConnectionTouch) do
            conn:Disconnect()
        end
        MobileAimbot.ConnectionTouch = nil
    end
    
    if MobileAimbot.FOVCircle then
        MobileAimbot.FOVCircle:Remove()
        MobileAimbot.FOVCircle = nil
    end
    
    MobileAimbot.ActiveTouches = {}
    MobileAimbot.LockedTarget = nil
end


})

    -- ── Utilities ────────────────────────────────────────────────────────
    Tabs.Misc:AddSection("Utilities")

    Tabs.Misc:AddButton({
        Title = "Rejoin",
        Description = "Reconnect to the same server",
        Callback = function()
            Fluent:Notify({
                Title = "Rejoin",
                Content = "Reconnecting...",
                Duration = 3
            })

            local TeleportService = game:GetService("TeleportService")
            local Players = game:GetService("Players")
            local LocalPlayer = Players.LocalPlayer

            if #Players:GetPlayers() <= 1 then
                -- Si estás solo → teleport normal al place
                TeleportService:Teleport(game.PlaceId, LocalPlayer)
            else
                -- Si hay más jugadores → intenta volver al mismo JobId
                TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer)
            end
        end
    })

    Tabs.Misc:AddButton({
        Title = "Server Hop",
        Description = "Join another server",
        Callback = function()
            Fluent:Notify({
                Title = "Server Hop",
                Content = "Looking for available server...",
                Duration = 4
            })

            local HttpService = game:GetService("HttpService")
            local TeleportService = game:GetService("TeleportService")
            local LocalPlayer = game.Players.LocalPlayer

            local success, servers = pcall(function()
                return HttpService:JSONDecode(
                    game:HttpGet(
                        "https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
                    )
                )
            end)

            if not success or not servers or not servers.data then
                Fluent:Notify({
                    Title = "Server Hop",
                    Content = "Error",
                    Duration = 5
                })
                return
            end

            for _, server in ipairs(servers.data) do
                if server.playing < server.maxPlayers and server.id ~= game.JobId then
                    Fluent:Notify({
                        Title = "Server Hop",
                        Content = "Joining server with " .. server.playing .. "/" .. server.maxPlayers .. " Players",
                        Duration = 4
                    })
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, server.id, LocalPlayer)
                    return  -- salimos después de intentar el primer servidor válido
                end
            end

            Fluent:Notify({
                Title = "Server Hop",
                Content = "No available servers with space were found",
                Duration = 5
            })
        end
    })

    -- Si quieres dejar el botón de Scan Points (aunque está en Dev en tu ejemplo)
    -- Puedes moverlo aquí o dejarlo en otra pestaña
    -- Tabs.Misc:AddButton({...}) ...

end

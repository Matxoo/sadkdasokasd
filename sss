    -- ==================== Auto Pickup Money (tu lógica tal cual) ====================
    local AutoPickupMoney_Enabled = false
    local AutoPickupMoney_Connection = nil

    local function AutoPickupMoney_Enable()
        if AutoPickupMoney_Enabled then return end
        AutoPickupMoney_Enabled = true

        print("[AutoPickupMoney] Activado - Iniciando debug...")

        local remote = game:GetService("ReplicatedStorage").Events:FindFirstChild("CZDPZUS")
        local moneyfolder = game:GetService("Workspace").Filter:FindFirstChild("SpawnedBread")

        print("[AutoPickupMoney] Remote encontrado:", remote ~= nil)
        print("[AutoPickupMoney] Folder encontrado:", moneyfolder ~= nil)

        if not remote then
            warn("[AutoPickupMoney] ERROR: Remote 'CZDPZUS' no encontrado. Busca el nombre correcto en ReplicatedStorage.Events")
            AutoPickupMoney_Enabled = false
            return
        end

        if not moneyfolder then
            warn("[AutoPickupMoney] ERROR: Folder 'SpawnedBread' no encontrado. Busca en workspace.Filter")
            AutoPickupMoney_Enabled = false
            return
        end

        print("[AutoPickupMoney] Todo OK - Iniciando loop...")

        local canPickup = true
        local startTick = tick()

        AutoPickupMoney_Connection = game:GetService("RunService").RenderStepped:Connect(function()
            if not AutoPickupMoney_Enabled then return end

            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not hrp then return end

            local function GetMoney()
                local maxdist = 25  -- Distancia de recogida
                local closest = nil
                local closestDist = math.huge

                for _, a in pairs(moneyfolder:GetChildren()) do
                    if a:IsA("Part") or a:IsA("MeshPart") then
                        local getdist = (hrp.Position - a.Position).Magnitude
                        if getdist < maxdist and getdist < closestDist then
                            closestDist = getdist
                            closest = a
                        end
                    end
                end

                print("[AutoPickupMoney] Objetos en folder:", #moneyfolder:GetChildren())
                print("[AutoPickupMoney] Dinero más cercano a:", closestDist, "studs")
                return closest
            end

            local foundmoney = GetMoney()
            if foundmoney then
                if canPickup then
                    print("[AutoPickupMoney] Recogiendo dinero...")
                    pcall(function()
                        remote:FireServer(foundmoney)
                    end)
                    canPickup = false
                    startTick = tick()
                    print("[AutoPickupMoney] Pickup ejecutado - Cooldown iniciado")
                end
            end

            if not canPickup and tick() - startTick >= 1 then
                canPickup = true
                print("[AutoPickupMoney] Cooldown terminado - Listo para siguiente")
            end
        end)

        Fluent:Notify({Title = "Auto Pickup Money", Content = "Enabled - Searching...", Duration = 3})
    end

    local function AutoPickupMoney_Disable()
        if not AutoPickupMoney_Enabled then return end
        AutoPickupMoney_Enabled = false

        if AutoPickupMoney_Connection then
            AutoPickupMoney_Connection:Disconnect()
            AutoPickupMoney_Connection = nil
        end

        print("[AutoPickupMoney] Desactivado")
        Fluent:Notify({Title = "Auto Pickup Money", Content = "Disabled", Duration = 2})
    end

    -- Conexión al toggle que ya tenés
    Options.AutoPickupMoney:OnChanged(function(value)
        if value then
            AutoPickupMoney_Enable()
        else
            AutoPickupMoney_Disable()
        end
    end)
    
end

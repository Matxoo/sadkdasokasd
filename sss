do
    Tabs.Misc:AddSection("Doors")
    --================== NEARBY DOOR INTERACTIONS (Open & Unlock) ==================--
    local OpenNearbyDoors_Enabled   = false
    local UnlockNearbyDoors_Enabled = false
    local DoorInteraction_Coroutine  = nil

    local function NearbyDoorInteraction_Loop()
        while (OpenNearbyDoors_Enabled or UnlockNearbyDoors_Enabled) do
            local waitTime = 0.25
            local char = LocalPlayer.Character
            local hrp  = char and char:FindFirstChild("HumanoidRootPart")
            local hum  = char and char:FindFirstChildOfClass("Humanoid")

            if not hrp or not hum or hum.Health <= 0 then
                task.wait(waitTime * 2)
                continue
            end

            local doorsFolder = workspace.Map:FindFirstChild("Doors")
            if not doorsFolder then
                warn("[Door Auto] No se encontró Workspace.Map.Doors → desactivando")
                OpenNearbyDoors_Enabled   = false
                UnlockNearbyDoors_Enabled = false
                break
            end

            local playerPos  = hrp.Position
            local checkRadius = 6

            for _, door in ipairs(doorsFolder:GetChildren()) do
                local doorBase = door:FindFirstChild("DoorBase")
                local values   = door:FindFirstChild("Values")
                local events   = door:FindFirstChild("Events")

                if doorBase and values and events then
                    if (playerPos - doorBase.Position).Magnitude <= checkRadius then
                        local toggleEvent = events:FindFirstChild("Toggle")
                        if not toggleEvent then continue end

                        -- Auto Unlock
                        if UnlockNearbyDoors_Enabled then
                            local locked = values:FindFirstChild("Locked")
                            local lockArg = door:FindFirstChild("Lock")
                            if locked and lockArg and locked.Value == true then
                                pcall(function()
                                    toggleEvent:FireServer("Unlock", lockArg)
                                end)
                            end
                        end

                        -- Auto Open
                        if OpenNearbyDoors_Enabled then
                            local openVal = values:FindFirstChild("Open")
                            local knob = door:FindFirstChild("Knob2") or door:FindFirstChild("Knob")
                            if openVal and knob and openVal.Value == false then
                                local isLocked = values:FindFirstChild("Locked")
                                local canOpen = not isLocked or not isLocked.Value
                                if canOpen then
                                    pcall(function()
                                        toggleEvent:FireServer("Open", knob)
                                    end)
                                end
                            end
                        end
                    end
                end
            end

            task.wait(waitTime)
        end
        DoorInteraction_Coroutine = nil
    end

    local function ManageDoorLoop()
        local shouldRun = OpenNearbyDoors_Enabled or UnlockNearbyDoors_Enabled
        if shouldRun and not DoorInteraction_Coroutine then
            DoorInteraction_Coroutine = task.spawn(NearbyDoorInteraction_Loop)
        end
    end

    local function OpenDoors_Enable()
        if OpenNearbyDoors_Enabled then return end
        OpenNearbyDoors_Enabled = true
        ManageDoorLoop()
        Fluent:Notify({Title = "Auto Open Doors", Content = "Enabled", Duration = 2})
    end

    local function OpenDoors_Disable()
        if not OpenNearbyDoors_Enabled then return end
        OpenNearbyDoors_Enabled = false
        ManageDoorLoop()
        Fluent:Notify({Title = "Auto Open Doors", Content = "Disabled", Duration = 2})
    end

    local function UnlockDoors_Enable()
        if UnlockNearbyDoors_Enabled then return end
        UnlockNearbyDoors_Enabled = true
        ManageDoorLoop()
        Fluent:Notify({Title = "Auto Unlock Doors", Content = "Enabled", Duration = 2})
    end

    local function UnlockDoors_Disable()
        if not UnlockNearbyDoors_Enabled then return end
        UnlockNearbyDoors_Enabled = false
        ManageDoorLoop()
        Fluent:Notify({Title = "Auto Unlock Doors", Content = "Disabled", Duration = 2})
    end

